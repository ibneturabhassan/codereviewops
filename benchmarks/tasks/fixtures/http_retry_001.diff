 class HttpClient:
     def __init__(self, transport):
         self.transport = transport
+
+    def get(self, url):
+        for attempt in range(4):
+            response = self.transport.get(url)
+            if response.status_code < 400:
+                return response
+            if attempt < 3:
+                continue
+        return response
